# ── Server (seller) ───────────────────────────────────────────────────────────
# Base mainnet wallet that receives USDC payments.
# This is the address AgentBill settles payments to.
RECEIVING_ADDRESS=0xYourReceivingWallet

# Locus API key for the server — used to call Claude via Locus Wrapped APIs
# after AgentBill confirms payment. Sign up at beta.paywithlocus.com
LOCUS_API_KEY=claw_dev_...

PORT=3000

# ── Agent (buyer) ─────────────────────────────────────────────────────────────
# Locus API key for the buying agent — must have USDC on Base mainnet.
# Can be the same key as LOCUS_API_KEY above for testing (note: self-payment
# may not be supported — use a second Locus account for a full demo).
LOCUS_API_KEY=claw_dev_...

# Public URL of the running AgentBill server (Locus proxy needs to reach it)
SERVER_URL=https://your-server.railway.app
